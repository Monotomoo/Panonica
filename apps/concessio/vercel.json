{
  "buildCommand": "cd ../.. && npm install --legacy-peer-deps && npm run build:panonica",
  "outputDirectory": "../panonica/dist",
  "installCommand": "cd ../.. && npm install --legacy-peer-deps",
  "framework": null,
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
